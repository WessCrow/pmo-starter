# ============================================================
# PMO-STARTER — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# IA — OpenAI ou Anthropic (Claude)
# Atualmente: USE_MOCK_AI=true (sem chamadas reais)
# ------------------------------------------------------------
USE_MOCK_AI=true

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# Qual provedor usar quando USE_MOCK_AI=false
AI_PROVIDER=openai   # openai | anthropic

# ------------------------------------------------------------
# SUPABASE — Auth + Banco de dados
# Atualmente: USE_MOCK_DB=true (dados em memória)
# ------------------------------------------------------------
USE_MOCK_DB=true

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------------------------------------------------------------
# STORAGE — Supabase Storage (upload de PDFs/briefings)
# Atualmente: USE_MOCK_STORAGE=true (simula upload local)
# ------------------------------------------------------------
USE_MOCK_STORAGE=true

SUPABASE_STORAGE_BUCKET=pmo-artifacts

# ------------------------------------------------------------
# EMAIL — Resend (convites, verificação)
# Atualmente: não utilizado no MVP
# ------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@pmo-starter.com

# ------------------------------------------------------------
# STRIPE — Planos Free/Pro
# Fora do MVP v1.0
# ------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
